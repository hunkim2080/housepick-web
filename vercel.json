{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "",
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/advance-phase",
      "schedule": "0 9 * * 1"
    }
  ]
}
