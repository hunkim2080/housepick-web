<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>예약 관리</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
  <div class="admin-container">
    <aside class="admin-sidebar">
      <h2>관리자</h2>
      <nav>
        <a href="/admin">대시보드</a>
        <a href="/admin/reservations" class="active">예약 관리</a>
        <a href="/admin/reviews">후기 관리</a>
        <a href="/admin/posts">블로그 콘텐츠</a>
        <a href="/admin/logout">로그아웃</a>
      </nav>
    </aside>
    
    <main class="admin-main">
      <header class="admin-header">
        <h1>예약 관리</h1>
      </header>
      
      <table class="admin-table">
        <thead>
          <tr>
            <th>예약번호</th>
            <th>고객명</th>
            <th>서비스</th>
            <th>지역</th>
            <th>시공일</th>
            <th>견적</th>
            <th>계약금</th>
            <th>상태</th>
          </tr>
        </thead>
        <tbody>
          <% reservations.forEach(reservation => { %>
            <tr>
              <td><%= reservation.id.substring(0, 8) %></td>
              <td><%= reservation.customerName %></td>
              <td><%= reservation.service %></td>
              <td><%= reservation.city %> <%= reservation.district %></td>
              <td><%= reservation.workDate %></td>
              <td><%= reservation.estimate ? reservation.estimate.finalPrice.toLocaleString() + '원' : '-' %></td>
              <td><%= reservation.depositAmount ? reservation.depositAmount.toLocaleString() + '원' : '-' %></td>
              <td><span class="status-badge <%= reservation.status %>"><%= reservation.status %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </main>
  </div>
</body>
</html>

