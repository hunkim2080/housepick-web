<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>전국 시공 전문 서비스</title>
  <meta name="description" content="전국 시공 가능한 줄눈시공, 입주청소, 탄성코트, 화장실 리모델링 전문 서비스. 방문 1회 원스톱 시공, 팀장 직영, 12개월 AS 보증">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="canonical" href="https://example.com<%= typeof canonical !== 'undefined' ? canonical : '' %>">
  
  <!-- Schema.org 구조화 데이터 -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "전국 시공 전문 서비스",
    "description": "줄눈시공, 입주청소, 탄성코트, 화장실 리모델링 전문",
    "areaServed": {
      "@type": "Country",
      "name": "대한민국"
    },
    "offers": {
      "@type": "Offer",
      "priceCurrency": "KRW"
    }
  }
  </script>
</head>
<body>
  <!-- 헤더 -->
  <header class="header">
    <div class="container">
      <div class="header-content">
        <a href="/" class="logo">
          <h1>전국 시공 전문</h1>
        </a>
        <nav class="nav">
          <a href="/julnoon">줄눈시공</a>
          <a href="/move-in-cleaning">입주청소</a>
          <a href="/elastic-coat">탄성코트</a>
          <a href="/bathroom-remodeling">화장실 리모델링</a>
          <a href="/reservation" class="btn-reservation">온라인 예약</a>
        </nav>
        <button class="mobile-menu-toggle" aria-label="메뉴">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </header>

  <!-- 메인 콘텐츠 -->
  <main class="main">
    <%- typeof body !== 'undefined' ? body : '' %>
  </main>

  <!-- 푸터 -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>서비스</h3>
          <ul>
            <li><a href="/julnoon">줄눈시공</a></li>
            <li><a href="/move-in-cleaning">입주청소</a></li>
            <li><a href="/elastic-coat">탄성코트</a></li>
            <li><a href="/bathroom-remodeling">화장실 리모델링</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h3>지역별 서비스</h3>
          <ul>
            <li><a href="/seoul">서울</a></li>
            <li><a href="/gyeonggi">경기</a></li>
            <li><a href="/incheon">인천</a></li>
            <li><a href="/busan">부산</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h3>고객센터</h3>
          <p>전화: 02-1234-5678</p>
          <p>이메일: info@example.com</p>
          <p>운영시간: 평일 09:00 - 18:00</p>
        </div>
        <div class="footer-section">
          <h3>신뢰 요소</h3>
          <div class="trust-badges">
            <span>✓ 공식 인증 업체</span>
            <span>✓ 12개월 AS 보증</span>
            <span>✓ 친환경 자재</span>
            <span>✓ 안전 인증</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 전국 시공 전문 서비스. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- 플로팅 예약 버튼 (모바일) -->
  <div class="floating-cta">
    <a href="/reservation" class="btn-floating">무료 견적 받기</a>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
